# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

# Number of observations to prefetch per family (default: 20)
# BATCH_SIZE=20

# iNaturalist place ID to filter observations by region (default: 97394 = North America)
# Find your place ID at https://www.inaturalist.org/places
# PLACE_ID=97394

# Only show observations with flowers (default: true)
# Set to false to include all plant photos (fruiting, vegetative, etc.)
# FLOWERING_ONLY=true

# Debug mode — shows build version in the lower-right corner
# BUILD_VERSION is set automatically in Docker builds
# DEBUG=false

# Theme overrides (applied on top of light/dark preset)
# THEME_BG=#f5f0e8
# THEME_TEXT=#333
# THEME_ACCENT=#2d5016
# THEME_ACCENT_HOVER=#3d6b20
